{
  "name": "Stux6 Portfolio DevEnv",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/ruby:1": {
      "version": "latest"
    }
  },
  "forwardPorts": [4000],
  "postCreateCommand": "bundle install",
  "customizations": {
    "vscode": {
      "extensions": [
        "rebornix.Ruby",
        "castwide.solargraph"
      ]
    }
  }
}
